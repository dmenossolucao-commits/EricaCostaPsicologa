rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Only allow authenticated, authorized administrators to read or write clinical patient documents
    match /patient_documents/{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.email == 'ericacostapsicologa7@gmail.com' ||
        request.auth.token.email == 'd-briciod2@hotmail.com' ||
        request.auth.token.email == 'admin@ericacostapsi.com.br'
      );
    }
    
    // Blog and site appearance media can be viewed by public, but uploaded only by authenticated admins
    match /blog_posts/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.email == 'ericacostapsicologa7@gmail.com' ||
        request.auth.token.email == 'd-briciod2@hotmail.com' ||
        request.auth.token.email == 'admin@ericacostapsi.com.br'
      );
    }

    match /site_content/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.email == 'ericacostapsicologa7@gmail.com' ||
        request.auth.token.email == 'd-briciod2@hotmail.com' ||
        request.auth.token.email == 'admin@ericacostapsi.com.br'
      );
    }
  }
}
